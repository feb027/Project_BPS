# Salin ke .env lalu sesuaikan. JANGAN commit .env ke git.
DJANGO_SECRET_KEY=ganti-dengan-kunci-acak-panjang
DJANGO_DEBUG=True

# Database. Kosongkan DB_ENGINE untuk pakai SQLite (pengembangan).
# Untuk PostgreSQL (produksi/tim), isi semua:
DB_ENGINE=
DB_NAME=bps_publikasi
DB_USER=bps
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=5432

# Host yang diizinkan saat dipakai di LAN (IP laptop host), pisah koma.
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
